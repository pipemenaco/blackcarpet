{
  "name": "blackcarpet",
  "version": "1.0.0",
  "description": "Sitio web de Black Carpet — productora de eventos inmersivos",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,api -c magenta,cyan \"vite\" \"node server/index.js\"",
