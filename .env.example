# Copia este archivo como .env y completa los valores reales.
# En Hostinger estas variables se configuran en el panel de la app Node.

# Puerto del servidor (Hostinger normalmente lo asigna automáticamente)
PORT=3000

# --- SMTP para el formulario de contacto ---
# Datos del correo de Hostinger (hPanel > Correos electrónicos)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contacto@blackcarpet.cl
SMTP_PASS=tu_password_del_correo

# Dirección que recibe los mensajes del formulario
CONTACT_TO=contacto@blackcarpet.cl

# Remitente que aparece en los correos (debe ser una cuenta válida del dominio)
CONTACT_FROM=contacto@blackcarpet.cl
